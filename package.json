{
  "name": "02-bases",
  "version": "0.0.1",
  "description": "Mi primera aplicación real de Node",
  "license": "MIT",
  "author": "Oscar Llamuca",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --import ts-node/esm\" jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "dev": "nodemon --watch src -e ts,js --exec tsx src/app.ts",
    "build": "npm run test && rimraf ./dist && tsc",
    "start": "node dist/app.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "get-age": "^1.0.1",
    "uuid": "^14.0.1",
    "winston": "^3.19.0"
  }
}
